<!-- ════════════════════════════════════════════════
  JAVASCRIPT
════════════════════════════════════════════════ -->
<script>
// ── CONFIG ──
const WHATSAPP = "916351551471";
const D = "Resham doori · Washable · Warranty · 150–200 kg capacity · Custom colour, size & design";

// ── PRODUCTS ──
// HOW TO ADD A PRODUCT:
//   Copy any line below and paste a new one.
//   Change: name, price, img (photo filename), badge, cat
//   badge options: "best" | "new" | "sale" | ""
//   cat options:   "jhula" | "baby" | "decor" | "purse"
//   Make sure the image file is uploaded to the same folder as index.html on Netlify!

const products = [
  { name: "Royal Canopy Jhula — Pink & White",  desc: D, price: "₹4,500",  img: "p1.jpg",  badge: "best", cat: "jhula" },
  { name: "Round Rope Swing — Pink",            desc: D, price: "₹2,999",  img: "p2.jpg",  badge: "new",  cat: "jhula" },
  { name: "Luxury Round Daybed Swing — Red",    desc: D, price: "₹12,650", img: "p3.jpg",  badge: "best", cat: "jhula" },
  { name: "Baby Sleeping Jhula",                desc: "Natural cotton · Wooden bead accents · Soft & safe for infants · Washable · Warranty", price: "₹3,999", img: "p4.jpg", badge: "best", cat: "baby" },
  { name: "Boho Canopy Swing — Cream",          desc: D, price: "₹9,500",  imgs: ["p5.jpg","p6.jpg"], badge: "new",  cat: "jhula" },
  { name: "Rust Canopy Daybed Swing",           desc: D, price: "₹9,900",  img: "p7.jpg",  badge: "best", cat: "jhula" },
  { name: "Cone Net Swing — Forest Green",      desc: D, price: "₹3,560",  img: "p8.jpg",  badge: "new",  cat: "jhula" },
  { name: "Royal Canopy Chair — Black & Gold",  desc: D, price: "₹2,500",  img: "p9.jpg",  badge: "sale", cat: "jhula" },
  { name: "Bell Jhula — Hot Pink",              desc: D, price: "₹4,100",  img: "p10.jpg", badge: "new",  cat: "jhula" },
  { name: "Kids Square Swing — Blue & White",   desc: D, price: "₹2,800",  img: "p11.jpg", badge: "new",  cat: "jhula" },
  { name: "Hand-Knotted Ganesha Wall Decor",    desc: "Handknotted resham rope · Beautiful home decoration · Customizable size & colour", price: "₹350", img: "p12.jpg", badge: "best", cat: "decor" },
  { name: "Relax & Nap Sleeping Jhula",         desc: "Ideal for relaxing, light sleeping & gentle swinging. " + D, price: "₹3,600", img: "p13.jpg", badge: "best", cat: "jhula" },
  { name: "Wall Hanging Pot Holder — Cream",    desc: "Handknotted resham rope · Wall mount with metal ring · Holds any standard pot · Beautiful tassel finish · Customize colour & size", price: "₹299", imgs: ["decor2a.jpg","decor2b.jpg"], badge: "new", cat: "decor" },
  { name: "Hanging Plant Holder — Green",       desc: "Handknotted resham rope · Ceiling hook style · Wooden bead detailing · Holds round pots perfectly · Customize colour", price: "₹100", imgs: ["decor3a.jpg","decor3b.jpg"], badge: "new", cat: "decor" },
  { name: "Boho Shoulder Bag — Olive Green",    desc: "Handknotted resham doori · Soft faux-fur lining inside · Spacious shoulder bag · Lightweight & strong · Customize colour", price: "₹499", img: "purse1.jpg", badge: "new", cat: "purse" },
  { name: "Classic Hobo Bag — Deep Maroon",     desc: "Handknotted resham doori · Rich maroon colour · Roomy crescent shape · Strong knotted strap · Customize colour & size", price: "₹499", img: "purse2.jpg", badge: "best", cat: "purse" },
  { name: "Fringe Sling Bag — Hot Pink",        desc: "Handknotted resham doori · Playful fringe detailing · Adjustable crossbody strap · Compact & cute · Customize colour", price: "₹299", img: "purse3.jpg", badge: "new", cat: "purse" },
  // ✏️ ADD NEW PRODUCTS BELOW THIS LINE:
  // { name: "Your Product Name", desc: D, price: "₹X,XXX", img: "filename.jpg", badge: "new", cat: "jhula" },
];

// ── RENDER PRODUCTS ──
const sliderState = {};

function renderProducts(items) {
  document.getElementById('products-grid').innerHTML = items.map((p, pi) => {
    const imgs = p.imgs || [p.img];
    const multi = imgs.length > 1;
    const imgHTML = multi
      ? `<div class="slider-wrap">
          <div class="slider-track" id="st-${pi}">
            ${imgs.map(src => `<img src="${src}" alt="${p.name}" loading="lazy"/>`).join('')}
          </div>
          <button class="slider-btn prev" onclick="slide(${pi},-1)" aria-label="Previous image">&#8249;</button>
          <button class="slider-btn next" onclick="slide(${pi}, 1)" aria-label="Next image">&#8250;</button>
          <div class="slider-dots" id="sd-${pi}">
            ${imgs.map((_,i) => `<button class="slider-dot${i===0?' active':''}" onclick="slideTo(${pi},${i})" aria-label="Image ${i+1}"></button>`).join('')}
          </div>
        </div>`
      : `<img src="${imgs[0]}" alt="${p.name}" loading="lazy"/>`;

    const badgeLabel = p.badge === 'best' ? 'Bestseller' : p.badge === 'new' ? 'New' : p.badge === 'sale' ? 'Sale' : '';
    return `
    <div class="product-card">
      <div class="product-img">
        ${p.badge ? `<div class="product-badge badge-${p.badge}">${badgeLabel}</div>` : ''}
        ${imgHTML}
      </div>
      <div class="product-body">
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <div class="product-price">${p.price}</div>
          <button class="order-btn" onclick="orderProduct('${p.name.replace(/'/g,"\\'")}','${p.price}')">Order</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function filterProducts(btn, cat) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(cat === 'all' ? products : products.filter(p => p.cat === cat));
}

function orderProduct(name, price) {
  const msg = encodeURIComponent(`Hi DK Jhula! 🙏\nI'd like to order:\n*${name}* (${price})\nPlease share availability, customization options & delivery details.`);
  window.open(`https://wa.me/${WHATSAPP}?text=${msg}`, '_blank');
  showToast('✓ Opening WhatsApp to place your order!');
}

// ── SLIDER ──
function slide(pi, dir) {
  const track = document.getElementById('st-' + pi);
  if (!track) return;
  const total = track.children.length;
  const cur = sliderState[pi] || 0;
  slideTo(pi, (cur + dir + total) % total);
}

function slideTo(pi, idx) {
  const track = document.getElementById('st-' + pi);
  const dots = document.querySelectorAll(`#sd-${pi} .slider-dot`);
  if (!track) return;
  sliderState[pi] = idx;
  track.style.transform = `translateX(-${idx * 100}%)`;
  dots.forEach((d, i) => d.classList.toggle('active', i === idx));
}

// ── TOAST ──
function showToast(text) {
  const t = document.getElementById('toast');
  t.textContent = text;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── MOBILE MENU ──
function openMenu()  { document.getElementById('mobile-menu').classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeMenu() { document.getElementById('mobile-menu').classList.remove('open'); document.body.style.overflow = ''; }

// ── REVIEWS ──
// Reviews are hardcoded in HTML above.
// To add more: copy a <div class="review-card">...</div> block in the HTML.

// ── INIT ──
renderProducts(products);
</script>
</body>
</html>
