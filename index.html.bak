<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DK Jhula — Handcrafted Swings & Home Decor</title>

<!-- SEO Meta Tags -->
<meta name="description" content="DK Jhula — handcrafted jhulas, baby cradles & home decor made with premium resham doori. 15+ years of craft. Fully washable, rope warranty, custom colour & size. Ships across India & worldwide from Anand, Gujarat."/>
<meta name="keywords" content="jhula, handmade jhula, resham doori swing, baby jhula, home decor, Anand Gujarat, custom jhula, boho swing, rope swing India"/>
<meta name="author" content="Daxaben K. Prajapati — DK Jhula"/>

<!-- Open Graph (WhatsApp / Facebook link preview) -->
<meta property="og:title" content="DK Jhula — Handcrafted with Love"/>
<meta property="og:description" content="Premium handcrafted jhulas & home decor. Resham doori, fully washable, custom colour & size. Ships worldwide from Anand, Gujarat."/>
<meta property="og:image" content="logo_png.jpg"/>
<meta property="og:url" content="https://dk-jhula.netlify.app/"/>
<meta property="og:type" content="website"/>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="DK Jhula — Handcrafted Swings & Decor"/>
<meta name="twitter:description" content="Premium resham doori jhulas & home decor. Custom colour, size & design. Ships India & worldwide."/>
<meta name="twitter:image" content="logo_png.jpg"/>

<!-- Favicon -->
<link rel="icon" href="logo_png.jpg" type="image/jpeg"/>

<!-- Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>

<style>
/* ── TOKENS ── */
:root {
  --cream:       #FAF6F0;
  --warm-white:  #FDF9F4;
  --brown-dark:  #3D1C08;
  --brown-mid:   #6B3A1F;
  --brown-light: #A0622A;
  --gold:        #C49A3C;
  --gold-light:  #E8C97A;
  --beige:       #E8DDD0;
  --beige-mid:   #D4C4B0;
  --text-dark:   #2C1505;
  --text-mid:    #5A3820;
  --text-light:  #9A7B60;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body:    'Jost', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--cream); color: var(--text-dark); overflow-x: hidden; }

/* ── NAVBAR ── */
nav {
  position: sticky; top: 0; z-index: 100;
  background: var(--warm-white);
  border-bottom: 1px solid var(--beige);
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 48px;
}
.nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
.nav-logo-img { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 2px solid var(--gold); }
.nav-brand-name { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--brown-dark); line-height: 1.1; }
.nav-brand-sub { font-size: 11px; color: var(--text-light); font-style: italic; }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a { font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-mid); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--brown-dark); }
.nav-right { display: flex; align-items: center; gap: 12px; }
.btn-wa {
  display: flex; align-items: center; gap: 8px;
  background: #25D366; color: white;
  padding: 9px 18px; border-radius: 6px;
  font-size: 13px; font-weight: 500; text-decoration: none;
  transition: opacity 0.2s;
}
.btn-wa:hover { opacity: 0.88; }
.btn-wa svg { width: 16px; height: 16px; flex-shrink: 0; }

/* Hamburger */
.hamburger { display: none; background: none; border: none; cursor: pointer; padding: 4px; }
.hamburger span { display: block; width: 22px; height: 2px; background: var(--brown-dark); margin: 5px 0; border-radius: 2px; transition: all 0.3s; }
.mobile-menu {
  display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--warm-white); z-index: 200; flex-direction: column;
  align-items: center; justify-content: center; gap: 32px;
}
.mobile-menu.open { display: flex; }
.mobile-menu a { font-size: 22px; font-family: var(--font-display); color: var(--brown-dark); text-decoration: none; letter-spacing: 1px; }
.mobile-menu a:hover { color: var(--gold); }
.mobile-close {
  position: absolute; top: 20px; right: 24px;
  background: none; border: none; font-size: 28px; cursor: pointer; color: var(--text-mid);
}

/* ── FLOATING WHATSAPP ── */
.wa-float {
  position: fixed; bottom: 24px; right: 24px; z-index: 150;
  width: 56px; height: 56px; border-radius: 50%;
  background: #25D366; color: white;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(37,211,102,0.35);
  text-decoration: none; transition: transform 0.2s, box-shadow 0.2s;
}
.wa-float:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(37,211,102,0.45); }
.wa-float svg { width: 28px; height: 28px; }

/* ── HERO ── */
.hero {
  min-height: 85vh;
  background: var(--warm-white);
  display: grid; grid-template-columns: 1fr 1fr;
  align-items: center; padding: 64px 48px; gap: 48px;
  position: relative; overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute; top: -80px; right: -80px;
  width: 480px; height: 480px; border-radius: 50%;
  background: var(--beige); opacity: 0.3; pointer-events: none;
}
.hero-left { position: relative; z-index: 1; }
.hero-tag {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--beige); border-radius: 20px;
  padding: 6px 16px; margin-bottom: 28px;
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--brown-mid); font-weight: 500;
}
.hero h1 {
  font-family: var(--font-display);
  font-size: 58px; font-weight: 600; line-height: 1.08;
  color: var(--brown-dark); margin-bottom: 16px;
}
.hero h1 em { color: var(--gold); font-style: italic; }
.hero-by { font-family: var(--font-display); font-size: 17px; font-style: italic; color: var(--text-light); margin-bottom: 20px; }
.hero-by strong { color: var(--gold); font-weight: 600; }
.hero-desc { font-size: 15px; color: var(--text-mid); line-height: 1.8; max-width: 420px; margin-bottom: 32px; }
.hero-stats { display: flex; gap: 36px; margin-bottom: 40px; }
.stat-num { font-family: var(--font-display); font-size: 34px; font-weight: 600; color: var(--brown-dark); line-height: 1; }
.stat-label { font-size: 11px; color: var(--text-light); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px; }
.hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
.hero-right { display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; }
.hero-img-frame {
  width: 380px; height: 380px; border-radius: 50%;
  border: 3px solid var(--gold); overflow: hidden;
  background: var(--cream);
}
.hero-img-frame img { width: 100%; height: 100%; object-fit: cover; }

/* Buttons */
.btn-primary {
  padding: 13px 30px; background: var(--brown-dark); color: var(--gold-light);
  border: none; border-radius: 6px; font-family: var(--font-body);
  font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase;
  font-weight: 500; cursor: pointer; text-decoration: none;
  transition: background 0.2s, transform 0.15s; display: inline-block;
}
.btn-primary:hover { background: var(--brown-mid); transform: translateY(-1px); }
.btn-outline {
  padding: 12px 26px; background: transparent; color: var(--brown-dark);
  border: 1.5px solid var(--brown-dark); border-radius: 6px;
  font-family: var(--font-body); font-size: 12px; letter-spacing: 1.5px;
  text-transform: uppercase; font-weight: 500; cursor: pointer;
  text-decoration: none; transition: all 0.2s; display: inline-block;
}
.btn-outline:hover { background: var(--brown-dark); color: var(--gold-light); }

/* ── DIVIDER STRIP ── */
.strip {
  background: var(--brown-dark); padding: 16px 48px;
  display: flex; align-items: center; justify-content: center;
  gap: 8px; flex-wrap: wrap;
}
.strip-text {
  font-family: var(--font-display); font-size: 15px;
  font-style: italic; color: var(--gold-light); letter-spacing: 0.5px;
}

/* ── WHY SECTION ── */
.why { background: var(--warm-white); padding: 72px 48px; border-bottom: 1px solid var(--beige); }
.section-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 8px; }
.section-title { font-family: var(--font-display); font-size: 38px; font-weight: 600; color: var(--brown-dark); line-height: 1.2; margin-bottom: 12px; }
.section-title em { color: var(--gold); font-style: italic; }
.section-sub { font-size: 15px; color: var(--text-light); max-width: 560px; line-height: 1.7; }
.section-head { margin-bottom: 48px; }
.section-head.center { text-align: center; }
.section-head.center .section-sub { margin: 0 auto; }

.why-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 16px; }
.why-card {
  background: var(--cream); border: 1px solid var(--beige);
  border-radius: 12px; padding: 22px 20px;
  border-left: 3px solid var(--gold);
  display: flex; flex-direction: column; gap: 6px;
}
.why-icon { font-size: 22px; }
.why-title { font-weight: 600; color: var(--brown-dark); font-size: 14px; line-height: 1.3; }
.why-point { font-size: 12px; color: var(--text-light); line-height: 1.5; }

/* ── SHOP ── */
.shop { padding: 72px 48px; }
.filter-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px; }
.filter-btn {
  padding: 8px 20px; border: 1.5px solid var(--beige-mid);
  border-radius: 30px; background: transparent; cursor: pointer;
  font-family: var(--font-body); font-size: 12px; color: var(--text-light);
  letter-spacing: 0.5px; transition: all 0.2s;
}
.filter-btn:hover, .filter-btn.active { background: var(--brown-dark); color: var(--gold-light); border-color: var(--brown-dark); }

.products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 24px; }
.product-card {
  background: var(--warm-white); border: 1px solid var(--beige);
  border-radius: 14px; overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}
.product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(61,28,8,0.1); }
.product-img { height: 240px; position: relative; background: #fff; overflow: hidden; }
.product-img img { width: 100%; height: 100%; object-fit: contain; padding: 8px; }

/* Slider */
.slider-wrap { position: relative; width: 100%; height: 100%; overflow: hidden; }
.slider-track { display: flex; height: 100%; transition: transform 0.4s cubic-bezier(.4,0,.2,1); will-change: transform; }
.slider-track img { min-width: 100%; height: 100%; object-fit: contain; padding: 8px; flex-shrink: 0; }
.slider-btn {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: rgba(61,28,8,0.55); border: none; color: #E8C97A;
  width: 28px; height: 28px; border-radius: 50%; cursor: pointer;
  font-size: 14px; display: flex; align-items: center; justify-content: center;
  z-index: 3; transition: background 0.2s;
}
.slider-btn:hover { background: rgba(61,28,8,0.85); }
.slider-btn.prev { left: 8px; }
.slider-btn.next { right: 8px; }
.slider-dots {
  position: absolute; bottom: 7px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 5px; z-index: 3;
}
.slider-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(61,28,8,0.22); border: none; cursor: pointer;
  padding: 0; transition: background 0.2s;
}
.slider-dot.active { background: var(--gold); }

.product-badge {
  position: absolute; top: 10px; left: 10px; z-index: 2;
  font-size: 10px; font-weight: 500; padding: 3px 10px; border-radius: 20px;
}
.badge-best { background: var(--gold); color: var(--brown-dark); }
.badge-new  { background: #C8E6C9; color: #1B5E20; }
.badge-sale { background: #FFCDD2; color: #B71C1C; }

.product-body { padding: 16px 18px 20px; }
.product-name { font-family: var(--font-display); font-size: 17px; font-weight: 600; color: var(--brown-dark); margin-bottom: 5px; line-height: 1.3; }
.product-desc { font-size: 11px; color: var(--text-light); line-height: 1.5; margin-bottom: 14px; }
.product-footer { display: flex; align-items: center; justify-content: space-between; }
.product-price { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--brown-mid); }
.order-btn {
  padding: 8px 16px; background: var(--brown-dark); color: var(--gold-light);
  border: none; border-radius: 6px; cursor: pointer;
  font-family: var(--font-body); font-size: 11px;
  letter-spacing: 1px; text-transform: uppercase; font-weight: 500;
  transition: background 0.2s;
}
.order-btn:hover { background: var(--brown-mid); }

/* ── ABOUT ── */
.about {
  background: var(--brown-dark);
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 64px; align-items: center; padding: 80px 48px;
}
.about-img-wrap { display: flex; justify-content: center; }
.about-img {
  width: 320px; height: 320px; border-radius: 50%;
  overflow: hidden; border: 3px solid var(--gold);
}
.about-img img { width: 100%; height: 100%; object-fit: cover; }
.about .section-label { color: var(--gold); }
.about .section-title { color: var(--gold-light); }
.about-owner {
  display: inline-block; background: rgba(196,154,60,0.12);
  border: 1px solid var(--gold); border-radius: 8px;
  padding: 10px 18px; margin-bottom: 20px;
}
.about-owner-label { font-size: 10px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }
.about-owner-name { font-family: var(--font-display); font-size: 20px; font-weight: 600; color: var(--gold-light); font-style: italic; }
.about-text { font-size: 14px; color: rgba(232,201,122,0.75); line-height: 1.85; margin-bottom: 18px; }
.about-quote { font-family: var(--font-display); font-size: 20px; font-style: italic; color: var(--gold); margin-bottom: 28px; line-height: 1.45; }
.about-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
.about-pill { padding: 5px 14px; border: 1px solid var(--gold); border-radius: 20px; color: var(--gold-light); font-size: 12px; letter-spacing: 0.5px; }

/* ── REVIEWS ── */
.reviews { background: var(--warm-white); padding: 72px 48px; }
.reviews-static {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 20px; margin-top: 8px;
}
.review-card {
  background: var(--cream); border: 1px solid var(--beige);
  border-radius: 14px; padding: 24px 22px;
  display: flex; flex-direction: column; gap: 12px;
}
.review-stars { color: var(--gold); font-size: 15px; letter-spacing: 2px; }
.review-text {
  font-family: var(--font-display); font-size: 15px;
  font-style: italic; color: var(--text-mid); line-height: 1.7; flex: 1;
}
.review-footer { border-top: 1px solid var(--beige); padding-top: 12px; }
.review-author { font-weight: 500; color: var(--brown-dark); font-size: 13px; }
.review-product { font-size: 11px; color: var(--text-light); margin-top: 2px; }

/* ── ORDER SECTION ── */
.order-section { background: var(--beige); text-align: center; padding: 72px 48px; }
.order-cards { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; margin-top: 40px; }
.order-card {
  background: var(--warm-white); border: 1px solid var(--beige-mid);
  border-radius: 14px; padding: 28px 30px; min-width: 180px;
  text-align: center; text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.order-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.07); }
.order-card-icon { font-size: 28px; margin-bottom: 10px; }
.order-card-title { font-weight: 500; color: var(--brown-dark); margin-bottom: 4px; font-size: 14px; }
.order-card-sub { font-size: 12px; color: var(--text-light); }

/* ── FOOTER ── */
footer {
  background: var(--text-dark); padding: 40px 48px;
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 20px;
}
.footer-logo { display: flex; align-items: center; gap: 14px; }
.footer-logo-img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--gold); }
.footer-brand { font-family: var(--font-display); font-size: 20px; color: var(--gold-light); font-weight: 600; }
.footer-brand span { color: var(--gold); }
.footer-sub { font-size: 11px; color: rgba(232,201,122,0.5); font-style: italic; margin-top: 2px; }
.footer-links { display: flex; gap: 24px; }
.footer-links a { font-size: 12px; color: rgba(232,201,122,0.5); text-decoration: none; letter-spacing: 1px; transition: color 0.2s; }
.footer-links a:hover { color: var(--gold-light); }
.footer-copy { font-size: 11px; color: rgba(232,201,122,0.3); }

/* ── TOAST ── */
.toast {
  position: fixed; bottom: 88px; right: 24px;
  background: var(--brown-dark); color: var(--gold-light);
  padding: 12px 20px; border-radius: 8px; font-size: 13px;
  border: 1px solid var(--gold); opacity: 0; pointer-events: none;
  transform: translateY(8px); transition: all 0.3s; z-index: 999;
}
.toast.show { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  nav { padding: 12px 20px; }
  .nav-links { display: none; }
  .hamburger { display: block; }
  .nav-right .btn-wa { display: none; }

  .hero { grid-template-columns: 1fr; padding: 40px 20px; min-height: auto; gap: 32px; }
  .hero-right { display: none; }
  .hero h1 { font-size: 38px; }

  .why { padding: 48px 20px; }
  .shop { padding: 48px 20px; }
  .about { grid-template-columns: 1fr; padding: 48px 20px; gap: 32px; }
  .about-img-wrap { display: none; }
  .reviews { padding: 48px 20px; }
  .order-section { padding: 48px 20px; }
  footer { flex-direction: column; text-align: center; padding: 32px 20px; }
  .footer-links { justify-content: center; }
  .strip { padding: 16px 20px; }

  .wa-float { bottom: 16px; right: 16px; }
}
</style>
</head>
<body>

<!-- ════════════════════════════════════════════════
  NAVBAR
════════════════════════════════════════════════ -->
<nav>
  <a class="nav-logo" href="#">
    <img class="nav-logo-img" src="logo_png.jpg" alt="DK Jhula"/>
    <div>
      <div class="nav-brand-name">DK Jhula</div>
      <div class="nav-brand-sub">by Daxaben K. Prajapati</div>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#shop">Shop</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#reviews">Reviews</a></li>
    <li><a href="#order">Order</a></li>
  </ul>
  <div class="nav-right">
    <a class="btn-wa" href="https://wa.me/916351551471" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>
    <button class="hamburger" onclick="openMenu()" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Navigation menu">
  <button class="mobile-close" onclick="closeMenu()" aria-label="Close menu">&times;</button>
  <a href="#shop"    onclick="closeMenu()">Shop</a>
  <a href="#about"   onclick="closeMenu()">About</a>
  <a href="#reviews" onclick="closeMenu()">Reviews</a>
  <a href="#order"   onclick="closeMenu()">Order</a>
  <a href="https://wa.me/916351551471" target="_blank" rel="noopener" style="color:#25D366;">WhatsApp Order</a>
</div>

<!-- Floating WhatsApp Button -->
<a class="wa-float" href="https://wa.me/916351551471" target="_blank" rel="noopener" aria-label="Order on WhatsApp">
